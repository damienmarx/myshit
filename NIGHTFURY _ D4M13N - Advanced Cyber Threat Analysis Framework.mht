.correlation-panel { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }

.correlation-item { background: rgba(10, 25, 41, 0.5); padding: 12px; border-radius: 5px; border-left: 4px solid var(--accent-blue); font-size: 0.9rem; }

.correlation-item h4 { margin-bottom: 8px; color: rgb(163, 212, 255); }

footer { text-align: center; margin-top: 30px; padding: 15px; color: rgb(108, 117, 125); font-size: 0.8rem; border-top: 1px solid rgba(255, 255, 255, 0.1); }

.security-notice { background: rgba(204, 51, 51, 0.1); border: 1px solid var(--accent-red); border-radius: 5px; padding: 12px; margin: 15px 0px; text-align: center; font-size: 0.9rem; }

.pulse { animation: 2s ease 0s infinite normal none running pulse; }

@keyframes pulse { 
  0% { box-shadow: rgba(0, 168, 255, 0.7) 0px 0px 0px 0px; }
  70% { box-shadow: rgba(0, 168, 255, 0) 0px 0px 0px 10px; }
  100% { box-shadow: rgba(0, 168, 255, 0) 0px 0px 0px 0px; }
}

.hidden { display: none; }

.status-indicator { display: inline-block; width: 10px; height: 10px; border-radius: 50%; margin-right: 5px; }

.status-online { background-color: var(--accent-green); box-shadow: 0 0 5px var(--accent-green); }

.status-offline { background-color: var(--accent-red); }

.status-busy { background-color: rgb(255, 153, 0); box-shadow: rgb(255, 153, 0) 0px 0px 5px; }

.threat-level { padding: 3px 8px; border-radius: 10px; font-size: 0.8rem; font-weight: bold; }

.threat-low { background-color: rgba(51, 204, 51, 0.2); color: var(--accent-green); }

.threat-medium { background-color: rgba(255, 153, 0, 0.2); color: rgb(255, 153, 0); }

.threat-high { background-color: rgba(204, 51, 51, 0.2); color: var(--accent-red); }

.threat-critical { background-color: rgba(153, 0, 0, 0.2); color: rgb(255, 51, 51); }

.chart-container { position: relative; height: 200px; width: 100%; }

.mission-item { background: rgba(10, 25, 41, 0.5); padding: 10px; border-radius: 5px; margin-bottom: 10px; border-left: 4px solid var(--accent-purple); }

.mission-title { font-weight: bold; margin-bottom: 5px; color: var(--cyber-teal); }

.mission-meta { font-size: 0.8rem; color: rgb(163, 212, 255); display: flex; justify-content: space-between; }

.mission-status { padding: 2px 6px; border-radius: 10px; font-size: 0.7rem; }

.status-active { background-color: rgba(51, 204, 51, 0.2); color: var(--accent-green); }

.status-completed { background-color: rgba(0, 102, 204, 0.2); color: var(--accent-blue); }

.status-pending { background-color: rgba(255, 153, 0, 0.2); color: rgb(255, 153, 0); }

.intel-item { background: rgba(10, 25, 41, 0.5); padding: 10px; border-radius: 5px; margin-bottom: 10px; border-left: 4px solid var(--accent-red); }

.intel-title { font-weight: bold; margin-bottom: 5px; display: flex; justify-content: space-between; }

.intel-meta { font-size: 0.8rem; color: rgb(163, 212, 255); }

.sidebar-nav { list-style: none; margin-top: 20px; }

.sidebar-nav li { margin-bottom: 10px; }

.sidebar-nav a { display: block; padding: 10px 15px; background: rgba(10, 25, 41, 0.5); border-radius: 5px; color: var(--text-light); text-decoration: none; transition: 0.3s; border-left: 3px solid transparent; }

.sidebar-nav a:hover, .sidebar-nav a.active { background: rgba(0, 102, 204, 0.2); border-left: 3px solid var(--accent-blue); }

.system-status { margin-top: 20px; padding-top: 15px; border-top: 1px solid rgba(255, 255, 255, 0.1); }

.status-item { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.9rem; }

.quick-actions { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 15px; }

.quick-btn { padding: 8px; background: rgba(0, 102, 204, 0.2); border: 1px solid var(--accent-blue); border-radius: 5px; color: var(--accent-blue); cursor: pointer; transition: 0.3s; font-size: 0.8rem; text-align: center; }

.quick-btn:hover { background: rgba(0, 102, 204, 0.4); }

.notification { position: fixed; top: 20px; right: 20px; padding: 15px 20px; background: var(--secondary-dark); border-left: 4px solid var(--accent-green); border-radius: 5px; box-shadow: rgba(0, 0, 0, 0.3) 0px 5px 15px; z-index: 1000; transform: translateX(150%); transition: transform 0.3s; }

.notification.show { transform: translateX(0px); }

.notification.error { border-left-color: var(--accent-red); }

.notification.warning { border-left-color: rgb(255, 153, 0); }

.ai-assistant { position: fixed; bottom: 20px; right: 20px; width: 60px; height: 60px; background: linear-gradient(45deg, var(--accent-purple), var(--accent-blue)); border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: rgba(0, 0, 0, 0.3) 0px 5px 15px; z-index: 999; transition: 0.3s; }

.ai-assistant:hover { transform: scale(1.1); }

.ai-panel { position: fixed; bottom: 90px; right: 20px; width: 350px; height: 400px; background: var(--secondary-dark); border-radius: 10px; box-shadow: rgba(0, 0, 0, 0.5) 0px 5px 25px; z-index: 998; display: none; flex-direction: column; border: 1px solid var(--accent-purple); }

.ai-panel.active { display: flex; }

.ai-header { padding: 15px; background: rgba(0, 0, 0, 0.2); border-bottom: 1px solid rgba(255, 255, 255, 0.1); border-radius: 10px 10px 0px 0px; }

.ai-messages { flex-grow: 1; padding: 15px; overflow-y: auto; }

.ai-input { padding: 15px; border-top: 1px solid rgba(255, 255, 255, 0.1); }

.ai-input input { width: 100%; padding: 10px; background: rgba(10, 25, 41, 0.7); border: 1px solid rgba(255, 255, 255, 0.2); border-radius: 5px; color: var(--text-light); }

.message { margin-bottom: 15px; padding: 10px; border-radius: 5px; max-width: 80%; }

.message.user { background: rgba(0, 102, 204, 0.2); margin-left: auto; border: 1px solid var(--accent-blue); }

.message.ai { background: rgba(153, 102, 204, 0.2); border: 1px solid var(--accent-purple); }
