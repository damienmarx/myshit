.export-btn { background: rgba(0, 102, 204, 0.2); border: 1px solid var(--accent-blue); color: var(--accent-blue); padding: 6px 12px; border-radius: 5px; cursor: pointer; transition: 0.3s; font-size: 0.8rem; }

